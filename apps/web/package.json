    "lucide-react": "^1.23.0",
    "mitt": "^3.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.8",
    "react-router": "^7.18.1",
