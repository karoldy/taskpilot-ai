{
  "name": "taskpilot-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "typecheck": "pnpm --filter web typecheck",
    "lint": "oxlint",
    "preview": "pnpm --filter web preview",
    "prepare": "husky",
    "codegen": "pnpm --filter web codegen",
    "storybook": "pnpm --filter web storybook",
    "build-storybook": "pnpm --filter web build-storybook",
    "dev:api": "pnpm --filter api start:dev",
    "build:api": "pnpm --filter api build",
    "start:api": "pnpm --filter api start:prod",
    "db:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:studio": "pnpm --filter api exec prisma studio",
    "format:api": "pnpm --filter api format"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.4",
    "typescript": "~6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msw",
      "esbuild",
      "@parcel/watcher",
      "@prisma/client",
      "prisma",
      "bcrypt",
      "@nestjs/core",
      "@prisma/engines",
      "@apollo/protobufjs"
    ],
    "overrides": {
      "graphql": "^16.14.2"
    }
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "prettier --write",
      "oxlint",
      "bash -c 'tsc -b --noEmit'"
    ],
    "apps/api/**/*.ts": [
      "prettier --write"
    ],
    "*.{json,md,yaml}": [
      "prettier --write"
    ]
  }
}
